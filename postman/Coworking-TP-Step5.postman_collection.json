  "item": [
    {
      "name": "01 - Create Room Paris",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Salle Paris A\",\n  \"city\": \"Paris\",\n  \"capacity\": 8,\n  \"type\": \"MEETING_ROOM\",\n  \"hourlyRate\": 45.00,\n  \"available\": true\n}"
        },
        "url": "{{baseUrl}}/api/rooms"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200/201', function () {",
              "    pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('roomId1', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
