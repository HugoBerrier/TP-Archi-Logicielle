    {
      "name": "06 - Overlap Reservation (must fail)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"roomId\": {{roomId1}},\n  \"memberId\": {{memberId2}},\n  \"startDateTime\": \"2030-03-20T11:00:00\",\n  \"endDateTime\": \"2030-03-20T13:00:00\"\n}"
        },
        "url": "{{baseUrl}}/api/reservations"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Overlap should fail', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 409]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
